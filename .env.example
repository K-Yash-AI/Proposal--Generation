# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-6

# Fireflies.ai
FIREFLIES_API_KEY=your_fireflies_api_key_here
FIREFLIES_TRANSCRIPTS_LIMIT=5

# Google Docs (choose one auth method)
# Option A: Service Account JSON file path (recommended for production)
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service_account.json
# Option B: OAuth2 credentials JSON file path (for personal use)
# GOOGLE_CREDENTIALS_FILE=path/to/credentials.json
# GOOGLE_TOKEN_FILE=token.json

# Your company info (Frutitions)
COMPANY_NAME=Frutitions
COMPANY_TAGLINE=Turning Ideas Into Reality
COMPANY_WEBSITE=https://frutitions.com
COMPANY_EMAIL=hello@frutitions.com
COMPANY_PHONE=+1 (555) 000-0000

# Default Google Doc template ID (from the URL: docs.google.com/document/d/TEMPLATE_ID/edit)
GOOGLE_TEMPLATE_DOC_ID=your_google_doc_template_id_here

# Output directory for generated proposals
OUTPUT_DIR=./proposals
